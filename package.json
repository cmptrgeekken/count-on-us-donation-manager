{
  "name": "count-on-us",
  "private": true,
  "scripts": {
    "build": "remix vite:build",
    "dev": "npm run dev:db && shopify app dev --no-update --localhost-port 3000",
    "dev:db": "docker compose up -d db",
    "config:link": "shopify app config link",
    "config:use:prod": "shopify app config use shopify.app.toml",
    "config:use:dev": "shopify app config use shopify.app.dev.toml",
    "env:use:dev": "shx cp .env.dev .env",
    "env:use:prod": "shx cp .env.production .env",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "npm run setup:deploy && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "setup:deploy": "prisma migrate deploy",
    "deploy:production": "bash scripts/deploy-production.sh",
    "backup:production": "bash scripts/backup-postgres.sh",
    "restore:production": "bash scripts/restore-postgres.sh",
    "prisma:generate:best-effort": "node ./scripts/prisma-generate-best-effort.mjs",
    "seed:dev": "node ./scripts/seed-dev.mjs",
    "seed:demo": "node ./scripts/seed-dev.mjs --preset=demo-store",
    "export:catalog": "node ./scripts/export-catalog-data.mjs",
    "export:financial": "node ./scripts/export-financial-data.mjs",
    "seed:import:catalog": "node ./scripts/seed-catalog-import.mjs",
    "backfill:financial": "node ./scripts/backfill-financial-data.mjs",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:install": "playwright install chromium",
    "test:ui:update": "playwright test --update-snapshots",
    "shopify": "shopify",
    "prisma": "prisma",
    "vite": "vite"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.13.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1061.0",
    "@aws-sdk/s3-request-presigner": "^3.1061.0",
    "@prisma/client": "^6.19.3",
    "@remix-run/node": "^2.17.5",
    "@remix-run/react": "^2.17.5",
    "@remix-run/serve": "^2.17.5",
    "@shopify/polaris": "^12.27.0",
    "@shopify/shopify-app-remix": "^4.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.0",
    "isbot": "^5.1.0",
    "pg-boss": "^12.15.0",
    "prisma": "^6.19.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite-tsconfig-paths": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.59.1",
    "@remix-run/dev": "^2.17.5",
    "@remix-run/fs-routes": "^2.17.5",
    "@remix-run/route-config": "^2.17.5",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.2.0",
    "@types/react": "^18.2.31",
    "@types/react-dom": "^18.2.14",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.16.2",
    "prettier": "^3.2.4",
    "shx": "^0.4.0",
    "typescript": "^5.2.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.2"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "resolutions": {
    "@graphql-tools/url-loader": "8.0.16",
    "@graphql-codegen/client-preset": "4.7.0",
    "@graphql-codegen/typescript-operations": "4.5.0",
    "minimatch": "9.0.7",
    "postcss": "8.5.15",
    "qs": "6.15.2",
    "tar": "7.5.16",
    "vite": "^6.4.3",
    "ws": "8.21.0"
  },
  "overrides": {
    "@graphql-tools/url-loader": "8.0.16",
    "@graphql-codegen/client-preset": "4.7.0",
    "@graphql-codegen/typescript-operations": "4.5.0",
    "minimatch": "9.0.7",
    "postcss": "8.5.15",
    "qs": "6.15.2",
    "tar": "7.5.16",
    "vite": "^6.4.3",
    "ws": "8.21.0"
  },
  "author": "Ken Beck"
}

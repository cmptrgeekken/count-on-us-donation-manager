# Development Shopify app credentials
SHOPIFY_API_KEY=your_dev_client_id
SHOPIFY_API_SECRET=your_dev_client_secret
SCOPES=write_app_proxy,read_files,read_locales,read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,read_orders,read_products,write_files,read_shopify_payments_payouts

# App URL - your fixed dev domain or tunnel URL, without a trailing slash.
SHOPIFY_APP_URL=https://shopify-dev.example.com

# Fixed port for Vite dev server
PORT=3000

# Database
DATABASE_URL=postgresql://countonus:your_password@localhost:5433/countonus?connection_limit=5
DB_PASSWORD=your_password

# Connection pools
DATABASE_POOL_SIZE=5
JOBS_POOL_SIZE=3

NODE_ENV=development

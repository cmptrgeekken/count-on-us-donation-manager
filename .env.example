# Shopify — copy values from Partner Dashboard > Apps > Count On Us > API credentials
SHOPIFY_API_KEY=your_client_id_from_partner_dashboard
SHOPIFY_API_SECRET=your_client_secret_from_partner_dashboard
SCOPES=write_app_proxy,read_locales,read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,read_orders,read_products,write_products,read_shopify_payments_payouts

# App URL — your tunnel or staging domain (no trailing slash)
SHOPIFY_APP_URL=https://your-tunnel-or-domain.example.com

# Database
DATABASE_URL=postgresql://countonus:your_password@localhost:5432/countonus?connection_limit=5
DB_PASSWORD=your_password

# Connection pools
DATABASE_POOL_SIZE=5
JOBS_POOL_SIZE=3

NODE_ENV=development

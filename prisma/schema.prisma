// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify session storage — managed by @shopify/shopify-app-session-storage-prisma
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Phase 1 tables

model Shop {
  id               String   @id @default(cuid())
  shopId           String   @unique
  shopifyDomain    String   @unique
  planTier         String?
  paymentRate      Decimal? @db.Decimal(5, 4)
  managedMarketsEnableDate DateTime?
  planOverride     Boolean  @default(false)
  currency         String   @default("USD")
  mistakeBuffer    Decimal? @db.Decimal(5, 4)
  defaultLaborRate Decimal? @db.Decimal(10, 4)
  defaultElectricityCostPerKwh Decimal? @db.Decimal(10, 6)
  effectiveTaxRate Decimal? @db.Decimal(5, 4)
  taxDeductionMode String   @default("dont_deduct")
  postPurchaseEmailEnabled Boolean @default(false)
  artistSubmissionNotificationEmail String?
  wizardStep       Int      @default(0)
  catalogSynced    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  wizardState WizardState?
  auditLogs   AuditLog[]
}

model WizardState {
  id             String   @id @default(cuid())
  shopId         String   @unique
  shop           Shop     @relation(fields: [shopId], references: [shopId])
  currentStep    Int      @default(0)
  completedSteps Int[]
  skippedSteps   Int[]
  updatedAt      DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [shopId])
  entity    String
  entityId  String?
  action    String
  actor     String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([shopId, createdAt])
}

model ImportBatch {
  id          String   @id @default(cuid())
  shopId      String
  kind        String
  status      String   @default("completed")
  sourceName  String?
  sourceType  String?
  dryRun      Boolean  @default(false)
  summary     Json?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  snapshots      OrderSnapshot[]
  shopifyCharges ShopifyChargeTransaction[]

  @@index([shopId, createdAt])
  @@index([shopId, kind, createdAt])
}

model HistoricalLineItemMapping {
  id                     String   @id @default(cuid())
  shopId                 String
  mappingKey             String
  lineTitle              String
  normalizedLineTitle    String
  variantTitle           String?
  normalizedVariantTitle String?
  sku                    String?
  variantId              String
  variant                Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  firstImportBatchId     String?
  lastImportBatchId      String?
  useCount               Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([shopId, mappingKey])
  @@index([shopId])
  @@index([shopId, variantId])
}

// No FK to Shop — DeletionJob must outlive the Shop row it references
model DeletionJob {
  id           String   @id @default(cuid())
  shopId       String   @unique
  scheduledFor DateTime
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Phase 2 tables

model MaterialLibraryItem {
  id               String   @id @default(cuid())
  shopId           String
  name             String
  type             String // "production" | "shipping"
  costingModel     String? // "counted" | "yield" | "uses"
  purchasePrice    Decimal  @db.Decimal(10, 4)
  purchaseQty      Decimal  @db.Decimal(10, 4)
  perUnitCost      Decimal  @db.Decimal(10, 6) // derived: purchasePrice ÷ purchaseQty
  totalUsesPerUnit Decimal? @db.Decimal(10, 4) // portioned-use only
  purchaseLink     String?
  weightGrams      Decimal? @db.Decimal(10, 3)
  unitDescription  String?
  status           String   @default("active") // "active" | "inactive"
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  templateLines CostTemplateMaterialLine[]
  variantLines  VariantMaterialLine[]
  packageLines  ShippingPackageMaterialLine[]

  @@index([shopId, status])
}

model EquipmentLibraryItem {
  id                              String   @id @default(cuid())
  shopId                          String
  name                            String
  hourlyRate                      Decimal? @db.Decimal(10, 4)
  hourlyRateMode                  String   @default("manual") // "manual" | "calculated"
  perUseCost                      Decimal? @db.Decimal(10, 4)
  perUseCostMode                  String   @default("manual") // "manual" | "calculated"
  usageBasis                      String   @default("time_and_unit") // "time" | "unit" | "time_and_unit"
  purchaseLink                    String?
  equipmentCost                   Decimal? @db.Decimal(10, 2)
  acquisitionCost                 Decimal? @db.Decimal(10, 2)
  expectedLifespanHours           Decimal? @db.Decimal(10, 4)
  expectedLifespanUnit            String   @default("hours") // "hours" | "uses"
  salvageValue                    Decimal? @db.Decimal(10, 2)
  wattsPerOperatingHour           Decimal? @db.Decimal(10, 4)
  electricityCostPerKwhOverride   Decimal? @db.Decimal(10, 6)
  status                          String   @default("active")
  notes                           String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  templateLines CostTemplateEquipmentLine[]
  variantLines  VariantEquipmentLine[]
  consumables   EquipmentConsumable[]

  @@index([shopId, status])
}

model EquipmentConsumable {
  id               String               @id @default(cuid())
  shopId           String
  equipmentId      String
  equipment        EquipmentLibraryItem @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  name             String
  replacementCost  Decimal              @db.Decimal(10, 2)
  lifespanQuantity Decimal              @db.Decimal(10, 4)
  lifespanUnit     String               // "hours" | "uses"
  sku              String?
  purchaseLink     String?
  status           String               @default("active")
  notes            String?
  sortOrder        Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  snapshotLines OrderSnapshotEquipmentConsumableLine[]

  @@index([shopId, equipmentId])
  @@index([shopId, status])
}

model CostTemplate {
  id                       String       @id @default(cuid())
  shopId                   String
  name                     String
  type                     String       @default("production") // "production" | "shipping"
  defaultShippingTemplateId String?
  defaultShippingTemplate  CostTemplate? @relation("DefaultShippingTemplate", fields: [defaultShippingTemplateId], references: [id])
  productionTemplates      CostTemplate[] @relation("DefaultShippingTemplate")
  description              String?
  defaultLaborMinutes      Decimal?      @db.Decimal(10, 4)
  defaultLaborRate         Decimal?      @db.Decimal(10, 4)
  status                   String       @default("active")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  materialLines  CostTemplateMaterialLine[]
  equipmentLines CostTemplateEquipmentLine[]
  productionVariantConfigs VariantCostConfig[] @relation("ProductionTemplate")
  shippingVariantConfigs   VariantCostConfig[] @relation("ShippingTemplate")

  @@index([shopId, status])
  @@index([shopId, type, status])
}

model CostTemplateMaterialLine {
  id               String                @id @default(cuid())
  templateId       String
  template         CostTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  materialId       String
  material         MaterialLibraryItem   @relation(fields: [materialId], references: [id])
  yield            Decimal?              @db.Decimal(10, 4)
  quantity         Decimal               @db.Decimal(10, 4)
  usesPerVariant   Decimal?              @db.Decimal(10, 4)
  variantOverrides VariantMaterialLine[]
}

model CostTemplateEquipmentLine {
  id               String                 @id @default(cuid())
  templateId       String
  template         CostTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  equipmentId      String
  equipment        EquipmentLibraryItem   @relation(fields: [equipmentId], references: [id])
  usageMode        String                 @default("direct")
  minutes          Decimal?               @db.Decimal(10, 4)
  uses             Decimal?               @db.Decimal(10, 4)
  yieldDurationMinutes Decimal?           @db.Decimal(10, 4)
  yieldUses        Decimal?               @db.Decimal(10, 4)
  yieldQuantity    Decimal?               @db.Decimal(10, 4)
  variantOverrides VariantEquipmentLine[]
}

model Product {
  id        String   @id @default(cuid())
  shopId    String
  shopifyId String // full GID: "gid://shopify/Product/123"
  title     String
  handle    String
  status    String // "active" | "archived" | "draft"
  syncedAt  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants         Variant[]
  causeAssignments ProductCauseAssignment[]
  artistAssignments ProductArtistAssignment[]

  @@unique([shopId, shopifyId])
  @@index([shopId])
}

model Variant {
  id        String   @id @default(cuid())
  shopId    String
  shopifyId String // full GID: "gid://shopify/ProductVariant/456"
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  title     String
  sku       String?
  price     Decimal  @db.Decimal(10, 2)
  syncedAt  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  costConfig        VariantCostConfig?
  providerMappings  ProviderVariantMapping[]
  historicalLineItemMappings HistoricalLineItemMapping[]

  @@unique([shopId, shopifyId])
  @@index([shopId])
}

model VariantCostConfig {
  id                   String        @id @default(cuid())
  shopId               String
  variantId            String        @unique
  variant              Variant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  productionTemplateId String?
  productionTemplate   CostTemplate? @relation("ProductionTemplate", fields: [productionTemplateId], references: [id])
  shippingTemplateId   String?
  shippingTemplate     CostTemplate? @relation("ShippingTemplate", fields: [shippingTemplateId], references: [id])
  preferredPackageId   String?
  preferredPackage     ShippingPackage? @relation(fields: [preferredPackageId], references: [id], onDelete: SetNull)
  packedLength         Decimal?      @db.Decimal(10, 3)
  packedWidth          Decimal?      @db.Decimal(10, 3)
  packedHeight         Decimal?      @db.Decimal(10, 3)
  packedWeightGrams    Decimal?      @db.Decimal(10, 3)
  canSharePackage      Boolean       @default(true)
  laborMinutes         Decimal?      @db.Decimal(10, 4)
  laborRate            Decimal?      @db.Decimal(10, 4) // overrides Shop.defaultLaborRate when set
  mistakeBuffer        Decimal?      @db.Decimal(5, 4) // overrides Shop.mistakeBuffer when set
  lineItemCount        Int           @default(0) // maintained on insert/delete of material+equipment lines (ADR-004)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  materialLines  VariantMaterialLine[]
  equipmentLines VariantEquipmentLine[]

  @@index([shopId])
  @@index([shopId, preferredPackageId])
}

model ShippingPackage {
  id                String   @id @default(cuid())
  shopId            String
  name              String
  shopifyPackageId  String?
  length            Decimal  @db.Decimal(10, 3)
  width             Decimal  @db.Decimal(10, 3)
  height            Decimal  @db.Decimal(10, 3)
  emptyWeightGrams  Decimal? @db.Decimal(10, 3)
  maxWeightGrams    Decimal? @db.Decimal(10, 3)
  source            String   @default("manual")
  status            String   @default("active")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  materialLines        ShippingPackageMaterialLine[]
  preferredByConfigs   VariantCostConfig[]
  orderAllocations     OrderPackageAllocation[]

  @@unique([shopId, shopifyPackageId])
  @@index([shopId, status])
}

model ShippingPackageMaterialLine {
  id         String              @id @default(cuid())
  shopId     String
  packageId  String
  package    ShippingPackage     @relation(fields: [packageId], references: [id], onDelete: Cascade)
  materialId String
  material   MaterialLibraryItem @relation(fields: [materialId], references: [id], onDelete: Restrict)
  quantity   Decimal             @db.Decimal(10, 4)

  @@unique([packageId, materialId])
  @@index([shopId])
}

model VariantMaterialLine {
  id             String                    @id @default(cuid())
  shopId         String
  configId       String
  config         VariantCostConfig         @relation(fields: [configId], references: [id], onDelete: Cascade)
  materialId     String
  material       MaterialLibraryItem       @relation(fields: [materialId], references: [id])
  templateLineId String?
  templateLine   CostTemplateMaterialLine? @relation(fields: [templateLineId], references: [id], onDelete: Cascade)
  yield          Decimal?                  @db.Decimal(10, 4)
  quantity       Decimal                   @db.Decimal(10, 4)
  usesPerVariant Decimal?                  @db.Decimal(10, 4)

  @@unique([configId, templateLineId])
  @@index([shopId])
}

model VariantEquipmentLine {
  id             String                     @id @default(cuid())
  shopId         String
  configId       String
  config         VariantCostConfig          @relation(fields: [configId], references: [id], onDelete: Cascade)
  equipmentId    String
  equipment      EquipmentLibraryItem       @relation(fields: [equipmentId], references: [id])
  templateLineId String?
  templateLine   CostTemplateEquipmentLine? @relation(fields: [templateLineId], references: [id], onDelete: Cascade)
  usageMode      String                     @default("direct")
  minutes        Decimal?                   @db.Decimal(10, 4)
  uses           Decimal?                   @db.Decimal(10, 4)
  yieldDurationMinutes Decimal?             @db.Decimal(10, 4)
  yieldUses      Decimal?                   @db.Decimal(10, 4)
  yieldQuantity  Decimal?                   @db.Decimal(10, 4)

  @@unique([configId, templateLineId])
  @@index([shopId])
}

model ProviderConnection {
  id                   String   @id @default(cuid())
  shopId               String
  provider             String
  authType             String
  status               String   @default("configured")
  displayName          String?
  providerAccountId    String?
  providerAccountName  String?
  credentialsEncrypted String?
  credentialHint       String?
  credentialUpdatedAt  DateTime?
  credentialExpiresAt  DateTime?
  lastValidatedAt      DateTime?
  lastValidationError  String?
  lastSyncedAt         DateTime?
  lastSyncError        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  mappings ProviderVariantMapping[]
  catalogVariants ProviderCatalogVariant[]
  syncRuns ProviderSyncRun[]

  @@unique([shopId, provider])
  @@index([shopId, status])
}

model ProviderVariantMapping {
  id                String             @id @default(cuid())
  shopId            String
  connectionId      String
  connection        ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  variantId         String
  variant           Variant            @relation(fields: [variantId], references: [id], onDelete: Cascade)
  provider          String
  status            String             @default("mapped")
  providerProductId String?
  providerProductTitle String?
  providerVariantId String?
  providerVariantTitle String?
  providerSku       String?
  matchMethod       String?
  lastCostSyncedAt  DateTime?
  lastSyncError     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  costLines ProviderCostCache[]

  @@unique([connectionId, variantId])
  @@index([shopId, provider])
  @@index([variantId])
}

model ProviderCatalogVariant {
  id                   String             @id @default(cuid())
  shopId               String
  connectionId         String
  connection           ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  provider             String
  providerProductId    String
  providerProductTitle String?
  providerVariantId    String
  providerVariantTitle String?
  providerSku          String?
  blueprintId          String?
  printProviderId      String?
  baseCost             Decimal?           @db.Decimal(10, 2)
  currency             String             @default("USD")
  sourceUpdatedAt      DateTime?
  syncedAt             DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([connectionId, providerVariantId])
  @@index([shopId, provider])
  @@index([shopId, providerSku])
}

model ProviderCostCache {
  id           String                 @id @default(cuid())
  mappingId    String
  mapping      ProviderVariantMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  costLineType String
  description  String?
  amount       Decimal                @db.Decimal(10, 2)
  currency     String                 @default("USD")
  syncedAt     DateTime
  sourceUpdatedAt DateTime?
  staleReason  String?
  createdAt    DateTime               @default(now())

  @@index([mappingId, syncedAt])
}

model ProviderSyncRun {
  id                String             @id @default(cuid())
  shopId            String
  connectionId      String
  connection        ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  provider          String
  trigger           String
  status            String             @default("queued")
  startedAt         DateTime?
  completedAt       DateTime?
  mappedCount       Int                @default(0)
  unmappedCount     Int                @default(0)
  cachedCostCount   Int                @default(0)
  errorSummary      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([shopId, provider, createdAt])
  @@index([connectionId, createdAt])
}

// Phase 3 tables

model Cause {
  id                  String   @id @default(cuid())
  shopId              String
  shopifyMetaobjectId String?
  name                String
  legalName           String?
  is501c3             Boolean  @default(false)
  description         String?
  iconUrl             String?
  donationLink        String?
  websiteUrl          String?
  instagramUrl        String?
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  productAssignments ProductCauseAssignment[]
  lineAllocations    LineCauseAllocation[]
  periodAllocations  CauseAllocation[]
  disbursements      Disbursement[]
  trueUpRedistributions TaxTrueUpRedistribution[]
  artistAssignments ArtistCauseAssignment[]

  @@index([shopId, status])
}

model Artist {
  id                    String   @id @default(cuid())
  shopId                String
  displayName           String
  creditName            String
  creditPreference      String   @default("artist_name")
  publicBio             String?
  websiteUrl            String?
  instagramUrl          String?
  contactName           String?
  contactEmail          String?
  status                String   @default("draft")
  paymentEnabled        Boolean  @default(false)
  defaultPayoutRate     Decimal  @default(10) @db.Decimal(5, 2)
  taxStatus             String   @default("not_required")
  paymentNotes          String?
  termsAcceptedAt       DateTime?
  effectiveAt           DateTime?
  revokedAt             DateTime?
  restrictedChannels    String?
  restrictedFormats     String?
  internalNotes         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  causeAssignments      ArtistCauseAssignment[]
  productAssignments    ProductArtistAssignment[]
  lineAllocations       LineArtistAllocation[]
  periodAllocations     ArtistAllocation[]
  payments              ArtistPayment[]
  convertedSubmissions  ArtistSubmission[]
  orderAttributions     OrderArtistAttribution[]
  customerAssociations  CustomerArtistAssociation[]

  @@index([shopId, status])
}

model CustomerArtistAssociation {
  id                          String   @id @default(cuid())
  shopId                      String
  shopifyCustomerId           String?
  normalizedCustomerEmailHash String?
  artistId                    String
  artist                      Artist   @relation(fields: [artistId], references: [id], onDelete: Restrict)
  source                      String   @default("manual")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([shopId, artistId])
  @@index([shopId, shopifyCustomerId])
  @@index([shopId, normalizedCustomerEmailHash])
}

model ArtistSubmission {
  id                       String   @id @default(cuid())
  shopId                   String
  submitterName            String
  email                    String
  artistName               String?
  publicLinks              String[] @default([])
  causeLinks               String[] @default([])
  preferredContactMethod   String?
  contactDetail            String?
  phoneNumber              String?
  instagramHandle          String?
  otherContact             String?
  localConnection          String?
  artworkIdea              String
  interestedFormats        String[] @default([])
  formatRestrictions       String?
  salesChannelRestrictions String?
  causePreference          String?
  causeInterests           String?
  artistSharePreference    String?
  proofApprovalPreference  String?
  artworkSampleLinks       String?
  notes                    String?
  termsAcknowledgedAt      DateTime
  termsVersion             String?
  termsText                String?
  paymentAcknowledgedAt    DateTime?
  status                   String   @default("new")
  source                   String   @default("storefront_widget")
  submitterIpHash          String?
  userAgent                String?
  internalNotes            String?
  convertedArtistId        String?
  convertedArtist          Artist?  @relation(fields: [convertedArtistId], references: [id], onDelete: SetNull)
  convertedAt              DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  files                    ArtistSubmissionFile[]

  @@index([shopId, status, createdAt])
  @@index([shopId, email])
  @@index([shopId, convertedArtistId])
}

model ArtistSubmissionFile {
  id               String           @id @default(cuid())
  shopId           String
  submissionId     String
  submission       ArtistSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  originalFileName String
  contentType      String
  byteSize         Int
  storageKey       String
  scanStatus       String           @default("pending")
  scanResult       String?
  uploadedAt       DateTime         @default(now())
  deletedAt        DateTime?

  @@unique([shopId, storageKey])
  @@index([shopId, submissionId])
  @@index([shopId, scanStatus])
}

model ArtistCauseAssignment {
  id         String   @id @default(cuid())
  shopId     String
  artistId   String
  artist     Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  causeId    String
  cause      Cause    @relation(fields: [causeId], references: [id], onDelete: Restrict)
  percentage Decimal  @db.Decimal(5, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([shopId, artistId, causeId])
  @@index([shopId])
  @@index([shopId, artistId])
}

model ProductArtistAssignment {
  id                    String   @id @default(cuid())
  shopId                String
  productId             String
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  shopifyProductId      String
  artistId              String
  artist                Artist   @relation(fields: [artistId], references: [id], onDelete: Restrict)
  attributionOrder      Int      @default(0)
  creditOverride        String?
  collaborationShare    Decimal  @default(100) @db.Decimal(5, 2)
  payoutEnabledOverride Boolean?
  payoutRateOverride    Decimal? @db.Decimal(5, 2)
  status                String   @default("active")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([shopId, productId, artistId])
  @@unique([shopId, shopifyProductId, artistId])
  @@index([shopId])
  @@index([shopId, productId])
  @@index([shopId, artistId])
}

model ProductCauseAssignment {
  id               String   @id @default(cuid())
  shopId           String
  shopifyProductId String
  causeId          String
  cause            Cause    @relation(fields: [causeId], references: [id], onDelete: Cascade)
  productId        String?
  product          Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  percentage       Decimal  @db.Decimal(5, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([shopId, shopifyProductId, causeId])
  @@unique([shopId, productId, causeId])
  @@index([shopId])
  @@index([shopId, productId])
}

model OrderSnapshot {
  id             String   @id @default(cuid())
  shopId         String
  shopifyOrderId String
  orderNumber    String?
  shopifyCustomerId String?
  normalizedCustomerEmailHash String?
  customerDisplayName String?
  origin         String   @default("webhook")
  periodId       String?
  period         ReportingPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)
  importBatchId  String?
  importBatch    ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  importedAt     DateTime?
  subtotalAmount Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  shippingAmount Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @default(0) @db.Decimal(10, 2)
  salesTaxCollected Decimal @default(0) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  lines OrderSnapshotLine[]
  packageAllocations OrderPackageAllocation[]
  packagingReviewItems PackagingReviewItem[]
  settlements OrderSettlement[]
  artistAttribution OrderArtistAttribution?

  @@unique([shopId, shopifyOrderId])
  @@index([shopId])
  @@index([shopId, shopifyCustomerId])
  @@index([shopId, normalizedCustomerEmailHash])
  @@index([shopId, periodId])
  @@index([shopId, importBatchId])
}

model OrderArtistAttribution {
  id          String        @id @default(cuid())
  shopId      String
  snapshotId  String        @unique
  snapshot    OrderSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  artistId    String
  artist      Artist        @relation(fields: [artistId], references: [id], onDelete: Restrict)
  source      String        @default("manual")
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([shopId, artistId])
  @@index([shopId, source])
}

model OrderSettlement {
  id               String   @id @default(cuid())
  shopId           String
  snapshotId       String?
  snapshot         OrderSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  periodId         String?
  period           ReportingPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)
  shopifyOrderId   String
  orderNumber      String?
  source           String   @default("manual")
  status           String   @default("needs_review")
  grossOrderAmount Decimal  @db.Decimal(10, 2)
  shopifyPaidAmount Decimal? @db.Decimal(10, 2)
  amountReceived   Decimal? @db.Decimal(10, 2)
  feeAmount        Decimal  @default(0) @db.Decimal(10, 2)
  currency         String   @default("USD")
  paidAt           DateTime?
  referenceId      String?
  notes            String?
  detectedReason   String?
  confirmedAt      DateTime?
  confirmedBy      String?
  ignoredAt        DateTime?
  ignoredBy        String?
  ignoreReason     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([shopId, shopifyOrderId])
  @@index([shopId, status])
  @@index([shopId, periodId])
  @@index([snapshotId])
}

model OrderPackageAllocation {
  id                 String        @id @default(cuid())
  shopId             String
  snapshotId         String
  snapshot           OrderSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  packageId          String?
  package            ShippingPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  packageName        String
  quantity           Int           @default(1)
  materialCost       Decimal       @db.Decimal(10, 4)
  source             String        @default("cartonization")
  confidence         String        @default("high")
  reason             String?
  allocationSignature String
  createdAt          DateTime      @default(now())

  @@index([shopId])
  @@index([snapshotId])
  @@unique([snapshotId, allocationSignature])
}

model PackagingReviewItem {
  id          String        @id @default(cuid())
  shopId      String
  snapshotId  String
  snapshot    OrderSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  status      String        @default("open")
  reason      String
  severity    String        @default("medium")
  payload     Json?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([shopId, status])
  @@index([snapshotId])
}

model OrderSnapshotLine {
  id                  String        @id @default(cuid())
  shopId              String
  snapshotId          String
  snapshot            OrderSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  shopifyLineItemId   String
  shopifyProductId    String?
  shopifyVariantId    String
  variantTitle        String
  productTitle        String
  quantity            Int
  salePrice           Decimal       @db.Decimal(10, 2)
  subtotal            Decimal       @db.Decimal(10, 2)
  laborCost           Decimal       @db.Decimal(10, 4)
  materialCost        Decimal       @db.Decimal(10, 4)
  packagingCost       Decimal       @db.Decimal(10, 4)
  equipmentCost       Decimal       @db.Decimal(10, 4)
  podCost             Decimal       @default(0) @db.Decimal(10, 4)
  mistakeBufferAmount Decimal       @db.Decimal(10, 4)
  totalCost           Decimal       @db.Decimal(10, 4)
  netContribution     Decimal       @db.Decimal(10, 4)
  laborMinutes        Decimal?      @db.Decimal(10, 2)
  laborRate           Decimal?      @db.Decimal(10, 2)
  podCostEstimated    Boolean       @default(false)
  podCostMissing      Boolean       @default(false)

  materialLines    OrderSnapshotMaterialLine[]
  equipmentLines   OrderSnapshotEquipmentLine[]
  podLines         OrderSnapshotPODLine[]
  causeAllocations LineCauseAllocation[]
  artistAllocations LineArtistAllocation[]
  adjustments      Adjustment[]

  @@index([shopId])
  @@index([snapshotId])
}

model OrderSnapshotMaterialLine {
  id             String            @id @default(cuid())
  snapshotLineId String
  snapshotLine   OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  materialId     String?
  materialName   String
  materialType   String
  costingModel   String?
  purchasePrice  Decimal           @db.Decimal(10, 2)
  purchaseQty    Decimal           @db.Decimal(10, 4)
  perUnitCost    Decimal           @db.Decimal(10, 4)
  yield_         Decimal?          @map("yield") @db.Decimal(10, 4)
  usesPerVariant Decimal?          @db.Decimal(10, 4)
  quantity       Decimal           @db.Decimal(10, 4)
  lineCost       Decimal           @db.Decimal(10, 4)
}

model OrderSnapshotEquipmentLine {
  id             String            @id @default(cuid())
  snapshotLineId String
  snapshotLine   OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  equipmentId    String?
  equipmentName  String
  hourlyRate     Decimal?          @db.Decimal(10, 4)
  perUseCost     Decimal?          @db.Decimal(10, 4)
  hourlyRateMode String            @default("manual")
  perUseCostMode String            @default("manual")
  usageMode      String            @default("direct")
  minutes        Decimal?          @db.Decimal(10, 2)
  uses           Decimal?          @db.Decimal(10, 2)
  yieldDurationMinutes Decimal?    @db.Decimal(10, 2)
  yieldUses      Decimal?          @db.Decimal(10, 2)
  yieldQuantity  Decimal?          @db.Decimal(10, 2)
  electricityCost Decimal          @default(0) @db.Decimal(10, 4)
  depreciationCost Decimal         @default(0) @db.Decimal(10, 4)
  consumablesCost Decimal          @default(0) @db.Decimal(10, 4)
  maintenanceCost Decimal          @default(0) @db.Decimal(10, 4)
  manualOverrideCost Decimal       @default(0) @db.Decimal(10, 4)
  lineCost       Decimal           @db.Decimal(10, 4)

  consumableLines OrderSnapshotEquipmentConsumableLine[]
}

model OrderSnapshotEquipmentConsumableLine {
  id                      String                     @id @default(cuid())
  snapshotEquipmentLineId String
  snapshotEquipmentLine   OrderSnapshotEquipmentLine @relation(fields: [snapshotEquipmentLineId], references: [id], onDelete: Cascade)
  consumableId            String?
  consumable              EquipmentConsumable?       @relation(fields: [consumableId], references: [id], onDelete: SetNull)
  consumableName          String
  lifespanUnit            String
  lineCost                Decimal                    @db.Decimal(10, 4)
}

model OrderSnapshotPODLine {
  id             String            @id @default(cuid())
  snapshotLineId String
  snapshotLine   OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  provider       String
  costLineType   String
  description    String
  amount         Decimal           @db.Decimal(10, 2)
}

model LineCauseAllocation {
  id             String            @id @default(cuid())
  shopId         String
  snapshotLineId String
  snapshotLine   OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  causeId        String
  cause          Cause             @relation(fields: [causeId], references: [id], onDelete: Restrict)
  causeName      String
  is501c3        Boolean
  percentage     Decimal           @db.Decimal(5, 2)
  amount         Decimal           @db.Decimal(10, 4)
  source         String            @default("product")
  artistId       String?
  artistName     String?

  @@index([shopId])
  @@index([shopId, artistId])
}

model LineArtistAllocation {
  id                     String            @id @default(cuid())
  shopId                 String
  snapshotLineId         String
  snapshotLine           OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  artistId               String
  artist                 Artist            @relation(fields: [artistId], references: [id], onDelete: Restrict)
  artistName             String
  creditName             String
  creditPreference       String
  collaborationShare     Decimal           @db.Decimal(5, 2)
  payoutEnabled          Boolean           @default(false)
  payoutRate             Decimal           @db.Decimal(5, 2)
  payoutBasis            Decimal           @db.Decimal(10, 4)
  payoutAmount           Decimal           @db.Decimal(10, 4)
  payoutExclusionReason  String?
  donationRoutableAmount Decimal           @db.Decimal(10, 4)
  createdAt              DateTime          @default(now())

  @@index([shopId])
  @@index([shopId, artistId])
  @@index([snapshotLineId])
}

model ReportingPeriod {
  id              String   @id @default(cuid())
  shopId          String
  status          String   @default("OPEN")
  source          String   @default("manual")
  startDate       DateTime
  endDate         DateTime
  shopifyPayoutId String?
  closedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  snapshots        OrderSnapshot[]
  causeAllocations CauseAllocation[]
  artistAllocations ArtistAllocation[]
  disbursements    Disbursement[]
  artistPayments    ArtistPayment[]
  taxTrueUps       TaxTrueUp[]
  appliedTrueUps   TaxTrueUp[]      @relation("AppliedTaxTrueUps")
  shopifyCharges   ShopifyChargeTransaction[]
  settlements      OrderSettlement[]
  recalculationRuns AnalyticalRecalculationRun[]

  @@unique([shopId, shopifyPayoutId])
  @@index([shopId, status])
  @@index([shopId, startDate, endDate])
}

model AnalyticalRecalculationRun {
  id          String          @id @default(cuid())
  shopId       String
  periodId     String
  period       ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  status       String          @default("queued")
  summary      Json?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())

  @@index([shopId, periodId, createdAt])
  @@index([periodId])
}

model CauseAllocation {
  id            String          @id @default(cuid())
  shopId        String
  periodId      String
  period        ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  causeId       String
  cause         Cause           @relation(fields: [causeId], references: [id], onDelete: Restrict)
  causeName     String
  is501c3       Boolean
  allocated     Decimal         @db.Decimal(10, 4)
  disbursed     Decimal         @default(0) @db.Decimal(10, 2)
  createdAt     DateTime        @default(now())
  applications  DisbursementApplication[]

  @@unique([periodId, causeId])
  @@index([shopId])
}

model ArtistAllocation {
  id            String          @id @default(cuid())
  shopId        String
  periodId      String
  period        ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  artistId      String
  artist        Artist          @relation(fields: [artistId], references: [id], onDelete: Restrict)
  artistName    String
  creditName    String
  allocated     Decimal         @db.Decimal(10, 4)
  paid          Decimal         @default(0) @db.Decimal(10, 2)
  createdAt     DateTime        @default(now())
  applications  ArtistPaymentApplication[]

  @@unique([periodId, artistId])
  @@index([shopId])
  @@index([shopId, artistId])
}

model ArtistPayment {
  id              String          @id @default(cuid())
  shopId          String
  periodId        String
  period          ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  artistId        String
  artist          Artist          @relation(fields: [artistId], references: [id], onDelete: Restrict)
  amount          Decimal         @db.Decimal(10, 2)
  paidAt          DateTime
  paymentMethod   String
  referenceId     String?
  notes           String?
  createdAt       DateTime        @default(now())
  applications    ArtistPaymentApplication[]

  @@index([shopId])
  @@index([periodId, artistId])
  @@index([shopId, artistId])
}

model ArtistPaymentApplication {
  id                 String           @id @default(cuid())
  shopId             String
  artistPaymentId    String
  artistPayment      ArtistPayment    @relation(fields: [artistPaymentId], references: [id], onDelete: Cascade)
  artistAllocationId String
  artistAllocation   ArtistAllocation @relation(fields: [artistAllocationId], references: [id], onDelete: Cascade)
  amount             Decimal          @db.Decimal(10, 2)
  createdAt          DateTime         @default(now())

  @@unique([artistPaymentId, artistAllocationId])
  @@index([shopId])
  @@index([artistAllocationId])
}

model Disbursement {
  id                      String          @id @default(cuid())
  shopId                  String
  periodId                String
  period                  ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  causeId                 String
  cause                   Cause           @relation(fields: [causeId], references: [id], onDelete: Restrict)
  amount                  Decimal         @db.Decimal(10, 2)
  allocatedAmount         Decimal         @default(0) @db.Decimal(10, 2)
  extraContributionAmount Decimal         @default(0) @db.Decimal(10, 2)
  feesCoveredAmount       Decimal         @default(0) @db.Decimal(10, 2)
  paidAt                  DateTime
  paymentMethod           String
  referenceId             String?
  receiptFileKey          String?
  createdAt               DateTime        @default(now())
  applications            DisbursementApplication[]

  @@index([shopId])
  @@index([periodId, causeId])
}

model DisbursementApplication {
  id               String         @id @default(cuid())
  shopId           String
  disbursementId   String
  disbursement     Disbursement   @relation(fields: [disbursementId], references: [id], onDelete: Cascade)
  causeAllocationId String
  causeAllocation  CauseAllocation @relation(fields: [causeAllocationId], references: [id], onDelete: Cascade)
  amount           Decimal        @db.Decimal(10, 2)
  createdAt        DateTime       @default(now())

  @@unique([disbursementId, causeAllocationId])
  @@index([shopId])
  @@index([causeAllocationId])
}

model TaxTrueUp {
  id                  String          @id @default(cuid())
  shopId              String
  periodId            String
  period              ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  appliedPeriodId     String?
  appliedPeriod       ReportingPeriod? @relation("AppliedTaxTrueUps", fields: [appliedPeriodId], references: [id], onDelete: SetNull)
  estimatedTax        Decimal         @db.Decimal(10, 2)
  actualTax           Decimal         @db.Decimal(10, 2)
  delta               Decimal         @db.Decimal(10, 2)
  redistributionNotes String?
  filedAt             DateTime
  createdAt           DateTime        @default(now())

  redistributions TaxTrueUpRedistribution[]

  @@index([shopId])
  @@index([periodId])
  @@index([appliedPeriodId])
}

model TaxTrueUpRedistribution {
  id          String    @id @default(cuid())
  shopId      String
  trueUpId    String
  trueUp      TaxTrueUp @relation(fields: [trueUpId], references: [id], onDelete: Cascade)
  causeId     String
  cause       Cause     @relation(fields: [causeId], references: [id], onDelete: Restrict)
  causeName   String
  amount      Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())

  @@index([shopId])
  @@index([trueUpId])
}

model ShopifyChargeTransaction {
  id                   String           @id @default(cuid())
  shopId               String
  shopifyTransactionId String
  periodId             String?
  period               ReportingPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)
  importBatchId        String?
  importBatch          ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  shopifyPayoutId      String?
  transactionType      String?
  description          String?
  amount               Decimal          @db.Decimal(10, 2)
  currency             String           @default("USD")
  processedAt          DateTime?
  createdAt            DateTime         @default(now())

  @@unique([shopId, shopifyTransactionId])
  @@index([shopId])
  @@index([shopId, shopifyPayoutId])
  @@index([shopId, importBatchId])
  @@index([periodId])
}

model Adjustment {
  id             String            @id @default(cuid())
  shopId         String
  snapshotLineId String
  snapshotLine   OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  type           String
  reason         String?
  laborAdj       Decimal           @default(0) @db.Decimal(10, 4)
  materialAdj    Decimal           @default(0) @db.Decimal(10, 4)
  packagingAdj   Decimal           @default(0) @db.Decimal(10, 4)
  equipmentAdj   Decimal           @default(0) @db.Decimal(10, 4)
  netContribAdj  Decimal           @default(0) @db.Decimal(10, 4)
  createdAt      DateTime          @default(now())
  actor          String            @default("system")

  @@index([shopId])
}

model BusinessExpense {
  id          String   @id @default(cuid())
  shopId      String
  category    String
  subType     String?
  name        String
  amount      Decimal  @db.Decimal(10, 2)
  expenseDate DateTime
  notes       String?
  createdAt   DateTime @default(now())

  @@index([shopId])
}

model TaxOffsetCache {
  id                   String   @id @default(cuid())
  shopId               String   @unique
  taxableExposure      Decimal  @db.Decimal(10, 2)
  deductionPool        Decimal  @db.Decimal(10, 2)
  cumulativeNetContrib Decimal  @db.Decimal(10, 2)
  widgetTaxSuppressed  Boolean  @default(false)
  updatedAt            DateTime @updatedAt
}

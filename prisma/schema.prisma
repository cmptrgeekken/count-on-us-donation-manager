// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shopify session storage — managed by @shopify/shopify-app-session-storage-prisma
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Phase 1 tables

model Shop {
  id               String   @id @default(cuid())
  shopId           String   @unique
  shopifyDomain    String   @unique
  planTier         String?
  paymentRate      Decimal? @db.Decimal(5, 4)
  managedMarketsEnableDate DateTime?
  planOverride     Boolean  @default(false)
  currency         String   @default("USD")
  mistakeBuffer    Decimal? @db.Decimal(5, 4)
  defaultLaborRate Decimal? @db.Decimal(10, 4)
  effectiveTaxRate Decimal? @db.Decimal(5, 4)
  taxDeductionMode String   @default("dont_deduct")
  postPurchaseEmailEnabled Boolean @default(true)
  wizardStep       Int      @default(0)
  catalogSynced    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  wizardState WizardState?
  auditLogs   AuditLog[]
}

model WizardState {
  id             String   @id @default(cuid())
  shopId         String   @unique
  shop           Shop     @relation(fields: [shopId], references: [shopId])
  currentStep    Int      @default(0)
  completedSteps Int[]
  skippedSteps   Int[]
  updatedAt      DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [shopId])
  entity    String
  entityId  String?
  action    String
  actor     String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([shopId, createdAt])
}

// No FK to Shop — DeletionJob must outlive the Shop row it references
model DeletionJob {
  id           String   @id @default(cuid())
  shopId       String   @unique
  scheduledFor DateTime
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Phase 2 tables

model MaterialLibraryItem {
  id               String   @id @default(cuid())
  shopId           String
  name             String
  type             String // "production" | "shipping"
  costingModel     String? // "yield" | "uses" — null for shipping materials
  purchasePrice    Decimal  @db.Decimal(10, 4)
  purchaseQty      Decimal  @db.Decimal(10, 4)
  perUnitCost      Decimal  @db.Decimal(10, 6) // derived: purchasePrice ÷ purchaseQty
  totalUsesPerUnit Decimal? @db.Decimal(10, 4) // uses-based only
  purchaseLink     String?
  weightGrams      Decimal? @db.Decimal(10, 3)
  unitDescription  String?
  status           String   @default("active") // "active" | "inactive"
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  templateLines CostTemplateMaterialLine[]
  variantLines  VariantMaterialLine[]

  @@index([shopId, status])
}

model EquipmentLibraryItem {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  hourlyRate    Decimal? @db.Decimal(10, 4)
  perUseCost    Decimal? @db.Decimal(10, 4)
  purchaseLink  String?
  equipmentCost Decimal? @db.Decimal(10, 2)
  status        String   @default("active")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  templateLines CostTemplateEquipmentLine[]
  variantLines  VariantEquipmentLine[]

  @@index([shopId, status])
}

model CostTemplate {
  id                       String       @id @default(cuid())
  shopId                   String
  name                     String
  type                     String       @default("production") // "production" | "shipping"
  defaultShippingTemplateId String?
  defaultShippingTemplate  CostTemplate? @relation("DefaultShippingTemplate", fields: [defaultShippingTemplateId], references: [id])
  productionTemplates      CostTemplate[] @relation("DefaultShippingTemplate")
  description              String?
  status                   String       @default("active")
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  materialLines  CostTemplateMaterialLine[]
  equipmentLines CostTemplateEquipmentLine[]
  productionVariantConfigs VariantCostConfig[] @relation("ProductionTemplate")
  shippingVariantConfigs   VariantCostConfig[] @relation("ShippingTemplate")

  @@index([shopId, status])
  @@index([shopId, type, status])
}

model CostTemplateMaterialLine {
  id               String                @id @default(cuid())
  templateId       String
  template         CostTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  materialId       String
  material         MaterialLibraryItem   @relation(fields: [materialId], references: [id])
  yield            Decimal?              @db.Decimal(10, 4)
  quantity         Decimal               @db.Decimal(10, 4)
  usesPerVariant   Decimal?              @db.Decimal(10, 4)
  variantOverrides VariantMaterialLine[]
}

model CostTemplateEquipmentLine {
  id               String                 @id @default(cuid())
  templateId       String
  template         CostTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  equipmentId      String
  equipment        EquipmentLibraryItem   @relation(fields: [equipmentId], references: [id])
  minutes          Decimal?               @db.Decimal(10, 4)
  uses             Decimal?               @db.Decimal(10, 4)
  variantOverrides VariantEquipmentLine[]
}

model Product {
  id        String   @id @default(cuid())
  shopId    String
  shopifyId String // full GID: "gid://shopify/Product/123"
  title     String
  handle    String
  status    String // "active" | "archived" | "draft"
  syncedAt  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants         Variant[]
  causeAssignments ProductCauseAssignment[]

  @@unique([shopId, shopifyId])
  @@index([shopId])
}

model Variant {
  id        String   @id @default(cuid())
  shopId    String
  shopifyId String // full GID: "gid://shopify/ProductVariant/456"
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  title     String
  sku       String?
  price     Decimal  @db.Decimal(10, 2)
  syncedAt  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  costConfig        VariantCostConfig?
  providerMappings  ProviderVariantMapping[]

  @@unique([shopId, shopifyId])
  @@index([shopId])
}

model VariantCostConfig {
  id                   String        @id @default(cuid())
  shopId               String
  variantId            String        @unique
  variant              Variant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  productionTemplateId String?
  productionTemplate   CostTemplate? @relation("ProductionTemplate", fields: [productionTemplateId], references: [id])
  shippingTemplateId   String?
  shippingTemplate     CostTemplate? @relation("ShippingTemplate", fields: [shippingTemplateId], references: [id])
  laborMinutes         Decimal?      @db.Decimal(10, 4)
  laborRate            Decimal?      @db.Decimal(10, 4) // overrides Shop.defaultLaborRate when set
  mistakeBuffer        Decimal?      @db.Decimal(5, 4) // overrides Shop.mistakeBuffer when set
  lineItemCount        Int           @default(0) // maintained on insert/delete of material+equipment lines (ADR-004)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  materialLines  VariantMaterialLine[]
  equipmentLines VariantEquipmentLine[]

  @@index([shopId])
}

model VariantMaterialLine {
  id             String                    @id @default(cuid())
  shopId         String
  configId       String
  config         VariantCostConfig         @relation(fields: [configId], references: [id], onDelete: Cascade)
  materialId     String
  material       MaterialLibraryItem       @relation(fields: [materialId], references: [id])
  templateLineId String?
  templateLine   CostTemplateMaterialLine? @relation(fields: [templateLineId], references: [id], onDelete: Cascade)
  yield          Decimal?                  @db.Decimal(10, 4)
  quantity       Decimal                   @db.Decimal(10, 4)
  usesPerVariant Decimal?                  @db.Decimal(10, 4)

  @@unique([configId, templateLineId])
  @@index([shopId])
}

model VariantEquipmentLine {
  id             String                     @id @default(cuid())
  shopId         String
  configId       String
  config         VariantCostConfig          @relation(fields: [configId], references: [id], onDelete: Cascade)
  equipmentId    String
  equipment      EquipmentLibraryItem       @relation(fields: [equipmentId], references: [id])
  templateLineId String?
  templateLine   CostTemplateEquipmentLine? @relation(fields: [templateLineId], references: [id], onDelete: Cascade)
  minutes        Decimal?                   @db.Decimal(10, 4)
  uses           Decimal?                   @db.Decimal(10, 4)

  @@unique([configId, templateLineId])
  @@index([shopId])
}

model ProviderConnection {
  id                   String   @id @default(cuid())
  shopId               String
  provider             String
  authType             String
  status               String   @default("configured")
  displayName          String?
  credentialsEncrypted String?
  credentialHint       String?
  lastSyncedAt         DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  mappings ProviderVariantMapping[]

  @@unique([shopId, provider])
  @@index([shopId, status])
}

model ProviderVariantMapping {
  id                String             @id @default(cuid())
  shopId            String
  connectionId      String
  connection        ProviderConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  variantId         String
  variant           Variant            @relation(fields: [variantId], references: [id], onDelete: Cascade)
  provider          String
  providerVariantId String?
  providerSku       String?
  matchMethod       String?
  lastCostSyncedAt  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  costLines ProviderCostCache[]

  @@unique([connectionId, variantId])
  @@index([shopId, provider])
  @@index([variantId])
}

model ProviderCostCache {
  id           String                 @id @default(cuid())
  mappingId    String
  mapping      ProviderVariantMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  costLineType String
  description  String?
  amount       Decimal                @db.Decimal(10, 2)
  currency     String                 @default("USD")
  syncedAt     DateTime
  createdAt    DateTime               @default(now())

  @@index([mappingId, syncedAt])
}

// Phase 3 tables

model Cause {
  id                  String   @id @default(cuid())
  shopId              String
  shopifyMetaobjectId String?
  name                String
  legalName           String?
  is501c3             Boolean  @default(false)
  description         String?
  iconUrl             String?
  donationLink        String?
  websiteUrl          String?
  instagramUrl        String?
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  productAssignments ProductCauseAssignment[]
  lineAllocations    LineCauseAllocation[]
  periodAllocations  CauseAllocation[]
  disbursements      Disbursement[]
  trueUpRedistributions TaxTrueUpRedistribution[]

  @@index([shopId, status])
}

model ProductCauseAssignment {
  id               String   @id @default(cuid())
  shopId           String
  shopifyProductId String
  causeId          String
  cause            Cause    @relation(fields: [causeId], references: [id], onDelete: Cascade)
  productId        String?
  product          Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  percentage       Decimal  @db.Decimal(5, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([shopId, shopifyProductId, causeId])
  @@index([shopId])
}

model OrderSnapshot {
  id             String   @id @default(cuid())
  shopId         String
  shopifyOrderId String
  orderNumber    String?
  origin         String   @default("webhook")
  periodId       String?
  period         ReportingPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  lines OrderSnapshotLine[]

  @@unique([shopId, shopifyOrderId])
  @@index([shopId])
  @@index([shopId, periodId])
}

model OrderSnapshotLine {
  id                  String        @id @default(cuid())
  shopId              String
  snapshotId          String
  snapshot            OrderSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  shopifyLineItemId   String
  shopifyVariantId    String
  variantTitle        String
  productTitle        String
  quantity            Int
  salePrice           Decimal       @db.Decimal(10, 2)
  subtotal            Decimal       @db.Decimal(10, 2)
  laborCost           Decimal       @db.Decimal(10, 4)
  materialCost        Decimal       @db.Decimal(10, 4)
  packagingCost       Decimal       @db.Decimal(10, 4)
  equipmentCost       Decimal       @db.Decimal(10, 4)
  podCost             Decimal       @default(0) @db.Decimal(10, 4)
  mistakeBufferAmount Decimal       @db.Decimal(10, 4)
  totalCost           Decimal       @db.Decimal(10, 4)
  netContribution     Decimal       @db.Decimal(10, 4)
  laborMinutes        Decimal?      @db.Decimal(10, 2)
  laborRate           Decimal?      @db.Decimal(10, 2)
  podCostEstimated    Boolean       @default(false)
  podCostMissing      Boolean       @default(false)

  materialLines    OrderSnapshotMaterialLine[]
  equipmentLines   OrderSnapshotEquipmentLine[]
  podLines         OrderSnapshotPODLine[]
  causeAllocations LineCauseAllocation[]
  adjustments      Adjustment[]

  @@index([shopId])
  @@index([snapshotId])
}

model OrderSnapshotMaterialLine {
  id             String            @id @default(cuid())
  snapshotLineId String
  snapshotLine   OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  materialId     String?
  materialName   String
  materialType   String
  costingModel   String?
  purchasePrice  Decimal           @db.Decimal(10, 2)
  purchaseQty    Decimal           @db.Decimal(10, 4)
  perUnitCost    Decimal           @db.Decimal(10, 4)
  yield_         Decimal?          @map("yield") @db.Decimal(10, 4)
  usesPerVariant Decimal?          @db.Decimal(10, 4)
  quantity       Decimal           @db.Decimal(10, 4)
  lineCost       Decimal           @db.Decimal(10, 4)
}

model OrderSnapshotEquipmentLine {
  id             String            @id @default(cuid())
  snapshotLineId String
  snapshotLine   OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  equipmentId    String?
  equipmentName  String
  hourlyRate     Decimal?          @db.Decimal(10, 2)
  perUseCost     Decimal?          @db.Decimal(10, 2)
  minutes        Decimal?          @db.Decimal(10, 2)
  uses           Decimal?          @db.Decimal(10, 2)
  lineCost       Decimal           @db.Decimal(10, 4)
}

model OrderSnapshotPODLine {
  id             String            @id @default(cuid())
  snapshotLineId String
  snapshotLine   OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  provider       String
  costLineType   String
  description    String
  amount         Decimal           @db.Decimal(10, 2)
}

model LineCauseAllocation {
  id             String            @id @default(cuid())
  shopId         String
  snapshotLineId String
  snapshotLine   OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  causeId        String
  cause          Cause             @relation(fields: [causeId], references: [id], onDelete: Restrict)
  causeName      String
  is501c3        Boolean
  percentage     Decimal           @db.Decimal(5, 2)
  amount         Decimal           @db.Decimal(10, 4)

  @@index([shopId])
}

model ReportingPeriod {
  id              String   @id @default(cuid())
  shopId          String
  status          String   @default("OPEN")
  source          String   @default("manual")
  startDate       DateTime
  endDate         DateTime
  shopifyPayoutId String?
  closedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  snapshots        OrderSnapshot[]
  causeAllocations CauseAllocation[]
  disbursements    Disbursement[]
  taxTrueUps       TaxTrueUp[]
  appliedTrueUps   TaxTrueUp[]      @relation("AppliedTaxTrueUps")
  shopifyCharges   ShopifyChargeTransaction[]
  recalculationRuns AnalyticalRecalculationRun[]

  @@unique([shopId, shopifyPayoutId])
  @@index([shopId, status])
  @@index([shopId, startDate, endDate])
}

model AnalyticalRecalculationRun {
  id          String          @id @default(cuid())
  shopId       String
  periodId     String
  period       ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  status       String          @default("queued")
  summary      Json?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())

  @@index([shopId, periodId, createdAt])
  @@index([periodId])
}

model CauseAllocation {
  id            String          @id @default(cuid())
  shopId        String
  periodId      String
  period        ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  causeId       String
  cause         Cause           @relation(fields: [causeId], references: [id], onDelete: Restrict)
  causeName     String
  is501c3       Boolean
  allocated     Decimal         @db.Decimal(10, 4)
  disbursed     Decimal         @default(0) @db.Decimal(10, 2)
  createdAt     DateTime        @default(now())
  applications  DisbursementApplication[]

  @@unique([periodId, causeId])
  @@index([shopId])
}

model Disbursement {
  id                      String          @id @default(cuid())
  shopId                  String
  periodId                String
  period                  ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  causeId                 String
  cause                   Cause           @relation(fields: [causeId], references: [id], onDelete: Restrict)
  amount                  Decimal         @db.Decimal(10, 2)
  allocatedAmount         Decimal         @default(0) @db.Decimal(10, 2)
  extraContributionAmount Decimal         @default(0) @db.Decimal(10, 2)
  feesCoveredAmount       Decimal         @default(0) @db.Decimal(10, 2)
  paidAt                  DateTime
  paymentMethod           String
  referenceId             String?
  receiptFileKey          String?
  createdAt               DateTime        @default(now())
  applications            DisbursementApplication[]

  @@index([shopId])
  @@index([periodId, causeId])
}

model DisbursementApplication {
  id               String         @id @default(cuid())
  shopId           String
  disbursementId   String
  disbursement     Disbursement   @relation(fields: [disbursementId], references: [id], onDelete: Cascade)
  causeAllocationId String
  causeAllocation  CauseAllocation @relation(fields: [causeAllocationId], references: [id], onDelete: Cascade)
  amount           Decimal        @db.Decimal(10, 2)
  createdAt        DateTime       @default(now())

  @@unique([disbursementId, causeAllocationId])
  @@index([shopId])
  @@index([causeAllocationId])
}

model TaxTrueUp {
  id                  String          @id @default(cuid())
  shopId              String
  periodId            String
  period              ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  appliedPeriodId     String?
  appliedPeriod       ReportingPeriod? @relation("AppliedTaxTrueUps", fields: [appliedPeriodId], references: [id], onDelete: SetNull)
  estimatedTax        Decimal         @db.Decimal(10, 2)
  actualTax           Decimal         @db.Decimal(10, 2)
  delta               Decimal         @db.Decimal(10, 2)
  redistributionNotes String?
  filedAt             DateTime
  createdAt           DateTime        @default(now())

  redistributions TaxTrueUpRedistribution[]

  @@index([shopId])
  @@index([periodId])
  @@index([appliedPeriodId])
}

model TaxTrueUpRedistribution {
  id          String    @id @default(cuid())
  shopId      String
  trueUpId    String
  trueUp      TaxTrueUp @relation(fields: [trueUpId], references: [id], onDelete: Cascade)
  causeId     String
  cause       Cause     @relation(fields: [causeId], references: [id], onDelete: Restrict)
  causeName   String
  amount      Decimal   @db.Decimal(10, 2)
  createdAt   DateTime  @default(now())

  @@index([shopId])
  @@index([trueUpId])
}

model ShopifyChargeTransaction {
  id                   String           @id @default(cuid())
  shopId               String
  shopifyTransactionId String
  periodId             String?
  period               ReportingPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)
  shopifyPayoutId      String?
  transactionType      String?
  description          String?
  amount               Decimal          @db.Decimal(10, 2)
  currency             String           @default("USD")
  processedAt          DateTime?
  createdAt            DateTime         @default(now())

  @@unique([shopId, shopifyTransactionId])
  @@index([shopId])
  @@index([shopId, shopifyPayoutId])
  @@index([periodId])
}

model Adjustment {
  id             String            @id @default(cuid())
  shopId         String
  snapshotLineId String
  snapshotLine   OrderSnapshotLine @relation(fields: [snapshotLineId], references: [id], onDelete: Cascade)
  type           String
  reason         String?
  laborAdj       Decimal           @default(0) @db.Decimal(10, 4)
  materialAdj    Decimal           @default(0) @db.Decimal(10, 4)
  packagingAdj   Decimal           @default(0) @db.Decimal(10, 4)
  equipmentAdj   Decimal           @default(0) @db.Decimal(10, 4)
  netContribAdj  Decimal           @default(0) @db.Decimal(10, 4)
  createdAt      DateTime          @default(now())
  actor          String            @default("system")

  @@index([shopId])
}

model BusinessExpense {
  id          String   @id @default(cuid())
  shopId      String
  category    String
  subType     String?
  name        String
  amount      Decimal  @db.Decimal(10, 2)
  expenseDate DateTime
  notes       String?
  createdAt   DateTime @default(now())

  @@index([shopId])
}

model TaxOffsetCache {
  id                   String   @id @default(cuid())
  shopId               String   @unique
  taxableExposure      Decimal  @db.Decimal(10, 2)
  deductionPool        Decimal  @db.Decimal(10, 2)
  cumulativeNetContrib Decimal  @db.Decimal(10, 2)
  widgetTaxSuppressed  Boolean  @default(false)
  updatedAt            DateTime @updatedAt
}

# Public hostname used by Caddy. Do not include a scheme.
APP_DOMAIN=app.example.com

# App bind target for a top-level reverse proxy such as Nginx Proxy Manager.
# Keep APP_BIND_IP at 127.0.0.1 when the proxy can reach the Docker VM locally.
APP_BIND_IP=127.0.0.1
APP_PORT=3000

# Shopify - copy values from Partner Dashboard > Apps > Count On Us > API credentials
SHOPIFY_API_KEY=your_client_id_from_partner_dashboard
SHOPIFY_API_SECRET=your_client_secret_from_partner_dashboard
SCOPES=write_app_proxy,read_files,read_locales,read_metaobject_definitions,write_metaobject_definitions,read_metaobjects,write_metaobjects,read_orders,read_products,write_files,read_shopify_payments_payouts

# App URL - must match Shopify app URL, redirects, webhooks, and app proxy configuration.
SHOPIFY_APP_URL=https://app.example.com

# Database
DB_PASSWORD=replace_with_a_long_random_password
DATABASE_POOL_SIZE=5
JOBS_POOL_SIZE=3

# Provider credentials encryption
PROVIDER_CREDENTIALS_SECRET=replace_with_at_least_32_random_bytes

# Receipt storage - production should use S3-compatible object storage.
RECEIPT_STORAGE_DRIVER=s3
RECEIPT_STORAGE_BUCKET=count-on-us-receipts
RECEIPT_STORAGE_REGION=us-east-1
RECEIPT_STORAGE_ENDPOINT=
RECEIPT_STORAGE_FORCE_PATH_STYLE=false
RECEIPT_STORAGE_ACCESS_KEY_ID=
RECEIPT_STORAGE_SECRET_ACCESS_KEY=
RECEIPT_STORAGE_SIGNING_SECRET=replace_with_at_least_32_random_bytes

# Post-purchase email. Use "log" until a real provider is configured.
POST_PURCHASE_EMAIL_DRIVER=log
POST_PURCHASE_EMAIL_FROM=donations@example.com
RESEND_API_KEY=

NODE_ENV=production
